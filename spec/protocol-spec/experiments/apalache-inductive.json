{
    "checker": {
        "discard-disabled": false,
        "no-deadlocks": true,
        "--write-intermediate": true,
        "tuning": {
            "search.invariant.mode": "after",
            "search.invariantFilter": "(2->.*)",
            "search.transitionFilter": "([0]->.*|1->0|2->[1-9][0-9]*)"
        }
    }
}
